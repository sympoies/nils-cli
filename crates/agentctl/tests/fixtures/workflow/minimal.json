{
  "schema_version": "agentctl.workflow.v1",
  "name": "minimal-provider-and-automation",
  "on_error": "continue-on-error",
  "steps": [
    {
      "id": "provider-step",
      "type": "provider",
      "provider": "codex",
      "task": "ping",
      "input": "minimal workflow provider step",
      "timeout_ms": 500,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      }
    },
    {
      "id": "automation-step",
      "type": "automation",
      "tool": "fzf-cli",
      "args": [
        "help"
      ],
      "timeout_ms": 500,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      }
    }
  ]
}
