{
  "schema_version": "agentctl.workflow.v1",
  "name": "automation-mixed-typed-steps",
  "on_error": "continue-on-error",
  "steps": [
    {
      "id": "macos-agent-step",
      "type": "automation",
      "tool": "macos-agent",
      "args": [
        "--format",
        "json",
        "preflight"
      ],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      }
    },
    {
      "id": "screen-record-step",
      "type": "automation",
      "tool": "screen-record",
      "args": [
        "--preflight"
      ],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      }
    },
    {
      "id": "image-processing-step",
      "type": "automation",
      "tool": "image-processing",
      "args": [
        "info",
        "--help"
      ],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      }
    },
    {
      "id": "fzf-cli-step",
      "type": "automation",
      "tool": "fzf-cli",
      "args": [
        "help"
      ],
      "timeout_ms": 5000,
      "retry": {
        "max_attempts": 1,
        "backoff_ms": 0
      }
    }
  ]
}
