# nils-cli bash completion: codex-cli (and cx* aliases)

if [[ -z ${BASH_VERSION-} ]]; then
  return 0 2>/dev/null || exit 0
fi

shopt -s progcomp 2>/dev/null || true

_nils_cli_codex_cli_source_common_bash() {
  declare -F _nils_cli_completion_common_load_generated_bash >/dev/null 2>&1 && return 0

  local source_file="${BASH_SOURCE[0]}"
  local script_dir=''
  script_dir="$(cd -- "$(dirname -- "$source_file")" && pwd -P)" || return 1

  local helper_path="${script_dir}/completion-adapter-common.bash"
  [[ -r "$helper_path" ]] || return 1

  # shellcheck source=/dev/null
  source "$helper_path" || return 1

  declare -F _nils_cli_completion_common_load_generated_bash >/dev/null 2>&1
}

_NILS_CODEX_CLI_BASH_GENERATED_STATE=0

_nils_cli_codex_cli_load_generated_bash() {
  _nils_cli_codex_cli_source_common_bash || return 1

  # command codex-cli completion bash
  _nils_cli_completion_common_load_generated_bash \
    "_NILS_CODEX_CLI_BASH_GENERATED_STATE" \
    "_nils_cli_codex_cli_generated" \
    "codex-cli" \
    "_codex-cli" \
    '^if \[\[ "\${BASH_VERSINFO\[0\]}" -eq 4 ' \
    '^fi$'
}

_nils_cli_codex_cli_complete() {
  if ! _nils_cli_codex_cli_load_generated_bash; then
    if declare -F _nils_cli_completion_common_fail_closed_no_legacy_bash >/dev/null 2>&1; then
      _nils_cli_completion_common_fail_closed_no_legacy_bash
    else
      COMPREPLY=()
    fi
    return 0
  fi

  local invoked_as="${COMP_WORDS[0]}"
  local -a words=("${COMP_WORDS[@]}")
  local cword="$COMP_CWORD"
  local cur="${COMP_WORDS[COMP_CWORD]}"
  local prev="${COMP_WORDS[COMP_CWORD-1]}"
  local -a inject=()
  local implied_async=''

  case "$invoked_as" in
    cxau) inject=(auth use) ;;
    cxar) inject=(auth refresh) ;;
    cxaa) inject=(auth auto-refresh) ;;
    cxdr) inject=(diag rate-limits) ;;
    cxdra) inject=(diag rate-limits); implied_async='1' ;;
    cxst) inject=(starship) ;;
    cxgp) inject=(agent prompt) ;;
    cxga) inject=(agent advice) ;;
    cxgk) inject=(agent knowledge) ;;
    cxgc) inject=(agent commit) ;;
    cxac) inject=(auth current) ;;
    cxas) inject=(auth sync) ;;
    cxcs) inject=(config show) ;;
    cxct) inject=(config set) ;;
  esac

  if [[ "$invoked_as" != "codex-cli" ]]; then
    words=( "codex-cli" "${inject[@]}" "${words[@]:1}" )
    cword=$((cword + ${#inject[@]}))
    cur="${words[cword]}"
    prev="${words[cword-1]}"
  fi

  if [[ -n "$implied_async" ]] && ! _nils_cli_completion_common_has_word_bash --async "${words[@]}"; then
    local -a with_async=( "${words[@]:0:$cword}" "--async" "${words[@]:$cword}" )
    words=( "${with_async[@]}" )
    cword=$((cword + 1))
    cur="${words[cword]}"
    prev="${words[cword-1]}"
  fi

  local -a saved_words=("${COMP_WORDS[@]}")
  local saved_cword="$COMP_CWORD"

  COMP_WORDS=("${words[@]}")
  COMP_CWORD="$cword"
  _nils_cli_codex_cli_generated "codex-cli" "$cur" "$prev"
  local rc=$?

  COMP_WORDS=("${saved_words[@]}")
  COMP_CWORD="$saved_cword"
  return $rc
}

if _nils_cli_codex_cli_source_common_bash; then
  _nils_cli_completion_common_register_bash _nils_cli_codex_cli_complete \
    codex-cli cx \
    cxgp cxga cxgk cxgc cxau cxar cxaa cxac cxas cxst cxdr cxdra \
    cxcs cxct
else
  complete -F _nils_cli_codex_cli_complete \
    codex-cli cx \
    cxgp cxga cxgk cxgc cxau cxar cxaa cxac cxas cxst cxdr cxdra \
    cxcs cxct
fi
