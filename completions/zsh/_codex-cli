_nils_cli_codex_cli_source_common_zsh() {
  (( $+functions[_nils_cli_completion_common_load_generated_zsh] )) && return 0

  local source_file="${functions_source[_codex-cli]-}"
  local helper_path=''

  if [[ -n "$source_file" && -r "$source_file" ]]; then
    helper_path="${source_file:h}/_completion-adapter-common.zsh"
    if [[ -r "$helper_path" ]]; then
      source "$helper_path" || return 1
      (( $+functions[_nils_cli_completion_common_load_generated_zsh] )) && return 0
    fi
  fi

  local dir=''
  for dir in "${fpath[@]}"; do
    helper_path="${dir}/_completion-adapter-common.zsh"
    if [[ -r "$helper_path" ]]; then
      source "$helper_path" || return 1
      (( $+functions[_nils_cli_completion_common_load_generated_zsh] )) && return 0
    fi
  done

  return 1
}

typeset -gi _NILS_CODEX_CLI_ZSH_GENERATED_STATE=0

_nils_cli_codex_cli_load_generated_zsh() {
  _nils_cli_codex_cli_source_common_zsh || return 1

  _nils_cli_completion_common_load_generated_zsh \
    "_NILS_CODEX_CLI_ZSH_GENERATED_STATE" \
    "_nils_cli_codex_cli_generated" \
    "codex-cli" \
    "_codex-cli" \
    '^if \[ "\$funcstack\[1\]" = "_nils_cli_codex_cli_generated" \]; then$' \
    '^fi$'
}

_nils_cli_codex_cli_apply_alias_rewrite_zsh() {
  local invoked_as="${words[1]-}"
  local -a inject=()
  local implied_async=''

  case "$invoked_as" in
    cxau) inject=(auth use) ;;
    cxar) inject=(auth refresh) ;;
    cxaa) inject=(auth auto-refresh) ;;
    cxdr) inject=(diag rate-limits) ;;
    cxdra) inject=(diag rate-limits); implied_async='1' ;;
    cxst) inject=(starship) ;;
    cxgp) inject=(agent prompt) ;;
    cxga) inject=(agent advice) ;;
    cxgk) inject=(agent knowledge) ;;
    cxgc) inject=(agent commit) ;;
    cxac) inject=(auth current) ;;
    cxas) inject=(auth sync) ;;
    cxcs) inject=(config show) ;;
    cxct) inject=(config set) ;;
  esac

  if [[ "$invoked_as" != "codex-cli" ]]; then
    local -a rewritten_words=('codex-cli')
    local token=''
    local -i idx=2

    for token in "${inject[@]}"; do
      rewritten_words+=("$token")
    done

    while (( idx <= ${#words[@]} )); do
      rewritten_words+=("${words[idx]}")
      (( idx++ ))
    done

    words=("${rewritten_words[@]}")
    (( CURRENT += ${#inject[@]} ))
  fi

  if [[ -n "$implied_async" && " ${words[*]-} " != *" --async "* ]]; then
    local -a async_words=()
    local -i idx=1

    while (( idx < CURRENT )); do
      async_words+=("${words[idx]}")
      (( idx++ ))
    done

    async_words+=("--async")

    while (( idx <= ${#words[@]} )); do
      async_words+=("${words[idx]}")
      (( idx++ ))
    done

    words=("${async_words[@]}")
    (( CURRENT++ ))
  fi
}

_codex-cli() {
  emulate -L zsh -o extendedglob

  local -i saved_current="$CURRENT"
  local -a saved_words=("${words[@]}")

  if ! _nils_cli_codex_cli_load_generated_zsh; then
    words=("${saved_words[@]}")
    CURRENT="$saved_current"
    if (( $+functions[_nils_cli_completion_common_fail_closed_zsh] )); then
      _nils_cli_completion_common_fail_closed_zsh
    fi
    return 1
  fi

  _nils_cli_codex_cli_apply_alias_rewrite_zsh
  _nils_cli_codex_cli_generated
  local rc=$?

  words=("${saved_words[@]}")
  CURRENT="$saved_current"
  return $rc
}

if _nils_cli_codex_cli_source_common_zsh; then
  _nils_cli_completion_common_register_zsh _codex-cli \
    codex-cli cx \
    cxgp cxga cxgk cxgc cxau cxar cxaa cxac cxas cxst cxdr cxdra \
    cxcs cxct
else
  compdef _codex-cli \
    codex-cli cx \
    cxgp cxga cxgk cxgc cxau cxar cxaa cxac cxas cxst cxdr cxdra \
    cxcs cxct
fi
