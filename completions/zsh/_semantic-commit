#compdef semantic-commit

_nils_cli_semantic_commit_source_common_zsh() {
  (( $+functions[_nils_cli_completion_common_load_generated_zsh] )) && return 0

  local source_file="${functions_source[_semantic-commit]-}"
  local helper_path=''

  if [[ -n "$source_file" && -r "$source_file" ]]; then
    helper_path="${source_file:h}/_completion-adapter-common.zsh"
    if [[ -r "$helper_path" ]]; then
      source "$helper_path" || return 1
      (( $+functions[_nils_cli_completion_common_load_generated_zsh] )) && return 0
    fi
  fi

  local dir=''
  for dir in "${fpath[@]}"; do
    helper_path="${dir}/_completion-adapter-common.zsh"
    if [[ -r "$helper_path" ]]; then
      source "$helper_path" || return 1
      (( $+functions[_nils_cli_completion_common_load_generated_zsh] )) && return 0
    fi
  done

  return 1
}

typeset -gi _NILS_SEMANTIC_COMMIT_ZSH_GENERATED_STATE=0

_nils_cli_semantic_commit_load_generated_zsh() {
  _nils_cli_semantic_commit_source_common_zsh || return 1

  _nils_cli_completion_common_load_generated_zsh \
    "_NILS_SEMANTIC_COMMIT_ZSH_GENERATED_STATE" \
    "_nils_cli_semantic_commit_generated" \
    "semantic-commit" \
    "_semantic-commit" \
    '^if \[ "\$funcstack\[1\]" = "_nils_cli_semantic_commit_generated" \]; then$' \
    '^fi$'
}

_semantic-commit() {
  emulate -L zsh -o extendedglob

  if ! _nils_cli_semantic_commit_load_generated_zsh; then
    if (( $+functions[_nils_cli_completion_common_fail_closed_no_legacy_zsh] )); then
      _nils_cli_completion_common_fail_closed_no_legacy_zsh
    fi
    return 1
  fi

  _nils_cli_semantic_commit_generated
}

if _nils_cli_semantic_commit_source_common_zsh; then
  _nils_cli_completion_common_register_zsh _semantic-commit semantic-commit
else
  compdef _semantic-commit semantic-commit
fi
