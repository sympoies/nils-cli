#!/usr/bin/env bash
set -euo pipefail

if command -v cli-template >/dev/null 2>&1; then
  exec cli-template "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run -q -p cli-template -- "$@"
fi

echo "cli-template: binary not found (install via cargo install or build the workspace)" >&2
exit 1
