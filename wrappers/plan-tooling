#!/usr/bin/env bash
set -euo pipefail

if command -v plan-tooling >/dev/null 2>&1; then
  exec plan-tooling "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run -q -p plan-tooling -- "$@"
fi

echo "plan-tooling: binary not found (install via cargo install or build the workspace)" >&2
exit 1

