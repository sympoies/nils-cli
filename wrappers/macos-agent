#!/usr/bin/env bash
set -euo pipefail

if command -v macos-agent >/dev/null 2>&1; then
  exec macos-agent "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run -q -p macos-agent -- "$@"
fi

echo "macos-agent: binary not found (install via cargo install or build the workspace)" >&2
exit 1
