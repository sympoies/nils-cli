#!/usr/bin/env bash
set -euo pipefail

if command -v screen-record >/dev/null 2>&1; then
  exec screen-record "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run -q -p screen-record -- "$@"
fi

echo "screen-record: binary not found (install via cargo install or build the workspace)" >&2
exit 1
